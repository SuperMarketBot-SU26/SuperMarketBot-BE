# SmartMarketBot - Environment Variables Template
# Copy to .env and fill in your actual values

# === Database ===
CONNECTION_STRING="Server=localhost,1434;Database=SuperMarketBot;User Id=sa;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True;"

# === JWT Authentication ===
JWT_SECRET_KEY="REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS"
JWT_ISSUER="SmartMarketBot"
JWT_AUDIENCE="SmartMarketBot.Client"
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# === Email (Gmail SMTP) ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
FROM_EMAIL="your_email@gmail.com"
FROM_NAME="SmartMarketBot"

# === MQTT Broker ===
MQTT_HOST="localhost"
MQTT_PORT=1883
MQTT_CLIENT_ID="smartmarketbot-backend"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_USE_TLS="false"

# === AI Service (Python) ===
AI_SERVICE_BASE_URL="http://localhost:8000"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_UPLOAD_PRESET="smartmarket_unsigned"
