# ============================================================
# SmartMarketBot — Environment Variables (.env.example)
# Copy file này thành .env và điền giá trị secret tương ứng
# ============================================================

# Connection String SQL Server (Azure SQL hoặc Local Server)
ConnectionStrings__DefaultConnection="Server=tcp:your-server.database.windows.net,1433;Initial Catalog=SuperMarketBot;User ID=your_user;Password=your_password;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

# JWT Configuration
Jwt__Issuer="SmartMarketBot"
Jwt__Audience="SmartMarketBot.Client"
Jwt__SecretKey="YOUR_SUPER_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG"
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# Email SMTP
Email__SmtpHost="smtp.gmail.com"
Email__SmtpPort=587
Email__SmtpUser="your_email@gmail.com"
Email__SmtpPassword="your_app_password"
Email__FromEmail="your_email@gmail.com"
Email__FromName="SmartMarketBot"

# MQTT HiveMQ Configuration
Mqtt__Host="your_hivemq_host.hivemq.cloud"
Mqtt__Port=8883
Mqtt__ClientId="smartmarketbot-backend"
Mqtt__Username="your_mqtt_username"
Mqtt__Password="your_mqtt_password"

# AI Service & Gemini API
AiService__BaseUrl="http://localhost:8000"
AiService__AnalyzeEndpoint="/vision/analyze"
AiService__VerifyFaceEndpoint="/verify"
AiService__GeminiApiKey="YOUR_GEMINI_API_KEY"

# Cloudinary Configuration
Cloudinary__CloudName="your_cloud_name"
Cloudinary__ApiKey="your_cloudinary_api_key"
Cloudinary__ApiSecret="your_cloudinary_api_secret"
