# Copy this file to .env and adjust for your environment.
# Ngưỡng cosine similarity DeepFace Facenet (0.0–1.0). Mặc định 0.40 — cao hơn = khó pass nhưng ít nhận nhầm.
# FACENET_THRESHOLD=0.38

# Local SQL Server Express / LocalDB (Windows typical):
DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=SuperMarketBot;Trusted_Connection=yes;Encrypt=no;

# SQL Server trên Docker (sau khi docker compose up, thay mật khẩu cho khớp .env.docker):
# DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost,1433;DATABASE=SuperMarketBot;UID=sa;PWD=YourStrongPasswordHere;Encrypt=yes;TrustServerCertificate=yes;
